# ─── Secrets / configuration locale ───────────────────────────────
# NE JAMAIS committer de clés. Utiliser env.example.json comme modèle.
env.json
*.env
.env
secrets.json

# ─── Supabase local ───────────────────────────────────────────────
# Artefacts du CLI + config liée à un projet précis (générés par `supabase link`).
supabase/.temp/
supabase/.branches/
supabase/config.toml
.supabase/
# Algorithme de translittération PROPRIÉTAIRE — NE PAS publier.
# (Le proxy `chat`, lui, est public : c'est un simple relais vers Anthropic.)
supabase/functions/transliterate/

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
